generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Users {
  id                    Int         @id @default(autoincrement())
  email                 String
  name                  String
  password              String
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  contentAI             ContentAI[]
  store                 Store[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @default(now())

  @@map("users")
}

model ContentAI {
  id          Int      @id @default(autoincrement())
  headline    String
  description String
  cta         String
  hashtags    String
  platform    String
  userId      Int
  user        Users    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contentAI")
}

model Store {
  id          Int          @id @default(autoincrement())
  name        String
  email       String
  number      String
  description String
  slug        String?      @unique
  typeMarket  String
  userId      Int
  user        Users        @relation(fields: [userId], references: [id])
  config      ConfigStore?
  products    Products[]
  customers   Customer[]
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())

  @@map("store")
}

model ConfigStore {
  id                  Int      @id @default(autoincrement())
  primaryColor        String
  secondaryColor      String
  logoUrl             String
  bannerHeroURL       String?
  bannerHeroMobileURL String?
  bannerSecondaryURL  String?
  bannerTertiaryURL   String?
  storeId             Int      @unique
  store               Store    @relation(fields: [storeId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("configStore")
}

model Products {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int             @default(0)
  storeId     Int
  slug        String
  store       Store           @relation(fields: [storeId], references: [id])
  images      ProductImages[]
  orderItems  OrderItem[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("products")
}

model ProductImages {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String
  product   Products @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productImages")
}

model Customer {
  id        Int      @id @default(autoincrement())
  storeId   Int
  store     Store    @relation(fields: [storeId], references: [id])
  fullName  String
  email     String
  cep       String?
  city      String?
  address   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer")
}

model Order {
  id         Int         @id @default(autoincrement())
  storeId    Int
  store      Store       @relation(fields: [storeId], references: [id])
  customerId Int
  customer   Customer    @relation(fields: [customerId], references: [id])
  status     String      @default("pending")
  subtotal   Float
  shipping   Float       @default(0)
  total      Float
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("order")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  product   Products @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float

  @@map("orderItem")
}
